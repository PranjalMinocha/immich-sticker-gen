{
  "title": "Sticker-Gen MLOps",
  "uid": "sticker-gen-mlops",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "tags": ["sticker-gen", "mlops"],
  "templating": {
    "list": [
      {
        "name": "time_window",
        "type": "custom",
        "label": "Time Window",
        "query": "1h,6h,24h",
        "current": { "text": "24h", "value": "24h" },
        "options": [
          { "text": "1h",  "value": "1h",  "selected": false },
          { "text": "6h",  "value": "6h",  "selected": false },
          { "text": "24h", "value": "24h", "selected": true  }
        ],
        "hide": 0,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [

    { "type": "row", "title": "Data Generation", "id": 100,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 101, "title": "Generate Requests ($time_window)", "type": "stat",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "targets": [{ "expr": "sum(increase(sticker_generate_requests_total[$time_window]))", "legendFormat": "" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#3274D9", "mode": "fixed" }, "noValue": "0" } }
    },

    {
      "id": 102, "title": "Saved Stickers ($time_window)", "type": "stat",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "targets": [{ "expr": "sum(increase(sticker_resolve_requests_total{saved=\"true\"}[$time_window]))", "legendFormat": "" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#73BF69", "mode": "fixed" }, "noValue": "0" } }
    },

    {
      "id": 103, "title": "Discarded Stickers ($time_window)", "type": "stat",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "targets": [{ "expr": "sum(increase(sticker_resolve_requests_total{saved=\"false\"}[$time_window]))", "legendFormat": "" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#FF780A", "mode": "fixed" }, "noValue": "0" } }
    },

    {
      "id": 104, "title": "API Errors ($time_window)", "type": "stat",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "targets": [{ "expr": "sum(increase(sticker_api_errors_total[$time_window]))", "legendFormat": "" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#F2495C", "mode": "fixed" }, "noValue": "0" } }
    },

    {
      "id": 105, "title": "Request Rate (per min)", "type": "timeseries",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "rate(sticker_generate_requests_total[2m]) * 60", "legendFormat": "Generate" },
        { "expr": "rate(sticker_resolve_requests_total{saved=\"true\"}[2m]) * 60", "legendFormat": "Save" },
        { "expr": "rate(sticker_edit_requests_total[2m]) * 60", "legendFormat": "Edit" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    {
      "id": 106, "title": "Edited Pixels (p50 / p95)", "type": "timeseries",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(sticker_edited_pixels_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(sticker_edited_pixels_bucket[5m])) by (le))", "legendFormat": "p95" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    { "type": "row", "title": "Serving Performance", "id": 200,
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 201, "title": "Inference Latency (ms)", "type": "timeseries",
      "gridPos": { "x": 0, "y": 13, "w": 8, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(sticker_inference_ms_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(sticker_inference_ms_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(sticker_inference_ms_bucket[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },

    {
      "id": 202, "title": "Encoder vs Decoder Latency (ms)", "type": "timeseries",
      "gridPos": { "x": 8, "y": 13, "w": 8, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(sticker_encoder_ms_bucket[5m])) by (le))", "legendFormat": "Encoder p50" },
        { "expr": "histogram_quantile(0.50, sum(rate(sticker_decoder_ms_bucket[5m])) by (le))", "legendFormat": "Decoder p50" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },

    {
      "id": 203, "title": "IoU Score Distribution", "type": "timeseries",
      "gridPos": { "x": 16, "y": 13, "w": 8, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(sticker_iou_score_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.25, sum(rate(sticker_iou_score_bucket[5m])) by (le))", "legendFormat": "p25" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "max": 1 } }
    },

    { "type": "row", "title": "User Behaviour", "id": 300,
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 301, "title": "Number of Edit Tries", "type": "timeseries",
      "gridPos": { "x": 0, "y": 21, "w": 12, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(sticker_num_tries_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.75, sum(rate(sticker_num_tries_bucket[5m])) by (le))", "legendFormat": "p75" },
        { "expr": "histogram_quantile(0.95, sum(rate(sticker_num_tries_bucket[5m])) by (le))", "legendFormat": "p95" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    {
      "id": 302, "title": "BBox Area Distribution", "type": "timeseries",
      "gridPos": { "x": 12, "y": 21, "w": 12, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(sticker_bbox_area_bucket[5m])) by (le))", "legendFormat": "p50 area" },
        { "expr": "histogram_quantile(0.95, sum(rate(sticker_bbox_area_bucket[5m])) by (le))", "legendFormat": "p95 area" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    { "type": "row", "title": "ML Pipeline", "id": 400,
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 401, "title": "Ready for Retraining", "type": "stat",
      "gridPos": { "x": 0, "y": 29, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "targets": [{ "expr": "retrain_ready_rows", "legendFormat": "" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "blue", "value": null },
            { "color": "green", "value": 500 }
          ]},
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "id": 402, "title": "Rows Used for Training", "type": "stat",
      "gridPos": { "x": 6, "y": 29, "w": 6, "h": 4 },
      "datasource": { "uid": "postgres" },
      "targets": [{ "rawSql": "SELECT COUNT(*) AS value FROM sticker_generation WHERE \"usedForTraining\" = TRUE", "format": "table" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#8AB8FF", "mode": "fixed" }, "noValue": "0" } }
    },

    {
      "id": 403, "title": "Rollback Count", "type": "stat",
      "gridPos": { "x": 12, "y": 29, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "targets": [{ "expr": "sticker_rollback_count", "legendFormat": "" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]},
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "id": 404, "title": "Error Rate", "type": "stat",
      "gridPos": { "x": 18, "y": 29, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(sticker_errors_total[10m])) / (sum(rate(sticker_requests_total[10m])) + 1e-9)", "legendFormat": "" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "0%",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.02 },
            { "color": "red", "value": 0.05 }
          ]},
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "id": 405, "title": "Drift Events", "type": "timeseries",
      "gridPos": { "x": 0, "y": 33, "w": 12, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "increase(drift_events_total[5m])", "legendFormat": "drift events (5m)" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } } }
    },

    {
      "id": 406, "title": "Drift Test Statistic", "type": "timeseries",
      "gridPos": { "x": 12, "y": 33, "w": 12, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(drift_test_stat_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(drift_test_stat_bucket[5m])) by (le))", "legendFormat": "p95" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    { "type": "row", "title": "Alerts", "id": 500,
      "gridPos": { "x": 0, "y": 40, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 501, "title": "Firing Alerts", "type": "alertlist",
      "gridPos": { "x": 0, "y": 41, "w": 24, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "options": {
        "alertInstanceLabelFilter": "",
        "alertName": "",
        "dashboardAlerts": false,
        "groupBy": [],
        "groupMode": "default",
        "maxItems": 20,
        "showRecentlyFired": true,
        "sortOrder": 1,
        "stateFilter": { "error": true, "firing": true, "noData": false, "normal": false, "pending": true }
      }
    }

  ]
}
